# Telegram
BOT_TOKEN=your_bot_token_here
CHANNEL_ID=-100xxxxxxxxxx
DISCUSSION_GROUP_ID=-100xxxxxxxxxx
WEBAPP_URL=https://your-domain.com
SUPERUSER_IDS=2100694356,other_id

# Database (для Docker Compose)
DB_PASSWORD=strong_random_password_here
# DATABASE_URL=postgresql://agl_user:password@db:5432/agl_dispatch (auto-set in compose)

# Pepper for login_key hashing (REQUIRED, >=32 chars).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# WARNING: changing this value invalidates all existing user keys.
LOGIN_KEY_PEPPER=replace_with_a_long_random_secret_at_least_32_chars

# Google Sheets — все три обязательны, иначе синхронизация выключена.
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}
GOOGLE_SHEET_ID=spreadsheet_id_here
GOOGLE_SHEET_NAME=лист запросов

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
